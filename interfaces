auto lo
iface lo inet loopback

iface enp3s0 inet manual

auto vmbr0
iface vmbr0 inet static
	address 192.168.1.243/24
	gateway 192.168.1.1
	bridge-ports enp3s0
	bridge-stp off
	bridge-fd 0

iface enp4s0 inet manual

iface enp1s0f0np0 inet manual

auto ovs_sriov
iface ovs_sriov inet static
    ovs_type OVSBridge
    ovs_ports enp1s0f0np0
    ovs_mtu 8996

iface enp1s0f1np1 inet manual


source /etc/network/interfaces.d/*
